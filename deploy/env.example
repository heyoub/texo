# texo-agent backend configuration — Qwen Cloud via DashScope compatible mode.
# Copy to /opt/texo-agent/env and fill in the key; the systemd unit loads this.
TEXO_LLM_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
TEXO_LLM_API_KEY=sk-REPLACE-ME
TEXO_LLM_CHAT_MODEL=qwen3.7-max
TEXO_LLM_PROPOSE_MODEL=qwen3.7-max
TEXO_LLM_RELATE_MODEL=qwen3.7-max
TEXO_LLM_EMBED_MODEL=text-embedding-v4
