# texo-agent backend configuration — Qwen Cloud via DashScope compatible mode.
# Copy to /opt/texo-agent/env and fill in the key; the systemd unit loads this.
OPENROUTER_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
OPENROUTER_API_KEY=sk-REPLACE-ME
OPENROUTER_CHAT_MODEL=qwen3.7-max
OPENROUTER_EXTRACTOR_MODEL=qwen3.7-max
OPENROUTER_RELATER_MODEL=qwen3.7-max
OPENROUTER_EMBED_MODEL=text-embedding-v4
