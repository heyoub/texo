---
interface Props {
  title?: string;
}
const { title = 'texo' } = Astro.props;
---

<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <style>
      /* ── Token layer ──
         Each named @token block resolves against an export in
         src/tokens/colors.tokens.ts and compiles to a :root custom
         property (--czap-<token-name>). */
      @token primary {}
      @token secondary {}
      @token surface {}
      @token panel {}
      @token text {}
      @token muted {}
      @token border {}
      @token current {}
      @token stale {}
      @token conflict {}

      /* ── Theme layer ──
         Variant selectors (html[data-theme=light/dark]) are emitted from the
         resolved ThemeDef in src/themes/dark.themes.ts; the block stays empty
         (a non-empty body compiles to a dead unconditional override). */
      @theme dark {}

      /* ── Reset + base ── */
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
      }

      html {
        font-family: system-ui, -apple-system, sans-serif;
        line-height: 1.55;
      }

      body {
        background: var(--czap-surface);
        color: var(--czap-text);
        min-height: 100dvh;
      }

      /* ── Top bar ── */
      .texo-nav {
        display: flex;
        align-items: center;
        gap: 0.875rem;
        padding: 0.75rem 1.25rem;
        border-bottom: 1px solid var(--czap-border);
        background: var(--czap-panel);
        position: sticky;
        top: 0;
        z-index: 100;
        flex-wrap: wrap;
      }

      .texo-nav__brand {
        font-weight: 800;
        font-size: 1.125rem;
        letter-spacing: -0.02em;
        color: var(--czap-primary);
        text-decoration: none;
      }

      .texo-nav__tag {
        font-size: 0.75rem;
        color: var(--czap-muted);
      }

      .texo-nav__link {
        font-size: 0.8125rem;
        color: var(--czap-muted);
        text-decoration: none;
        transition: color 0.15s;
      }
      .texo-nav__link:hover {
        color: var(--czap-primary);
      }

      .texo-nav__spacer {
        flex: 1;
      }

      /* Stream status dot — JS flips data-live on czap stream lifecycle. */
      .texo-nav__status {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        font-size: 0.75rem;
        color: var(--czap-muted);
      }
      .texo-nav__status::before {
        content: '';
        width: 0.5rem;
        height: 0.5rem;
        border-radius: 50%;
        background: var(--czap-muted);
      }
      .texo-nav__status[data-live='true']::before {
        background: var(--czap-current);
      }
      .texo-nav__status[data-live='error']::before {
        background: var(--czap-conflict);
      }

      .texo-theme-toggle {
        appearance: none;
        border: 1px solid var(--czap-border);
        background: var(--czap-panel);
        color: var(--czap-text);
        padding: 0.3rem 0.7rem;
        border-radius: 0.375rem;
        font-size: 0.8125rem;
        cursor: pointer;
        transition: background 0.15s, color 0.15s;
      }
      .texo-theme-toggle:hover {
        background: var(--czap-primary);
        color: #ffffff;
      }

      .texo-main {
        max-width: 80rem;
        margin: 0 auto;
        padding: 1.25rem;
      }
    </style>
  </head>
  <body>
    <nav class="texo-nav">
      <a class="texo-nav__brand" href="/">texo</a>
      <span class="texo-nav__tag">claim-chain memory · every answer carries its receipts</span>
      <a class="texo-nav__link" href="/">Agent</a>
      <a class="texo-nav__link" href="/drift.html">Drift</a>
      <div class="texo-nav__spacer"></div>
      <span class="texo-nav__status" id="stream-status" data-live="false">stream</span>
      <button class="texo-theme-toggle" id="theme-toggle">Theme</button>
    </nav>

    <main class="texo-main">
      <slot />
    </main>

    <script>
      const btn = document.getElementById('theme-toggle');
      btn?.addEventListener('click', () => {
        const html = document.documentElement;
        const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', next);
      });
    </script>
  </body>
</html>
