---
import { Font } from 'astro:assets';
import '../styles/ledger.css';

interface Props {
  title?: string;
  /** Hide the app chrome (header/HUD) for full-bleed surfaces. */
  bare?: boolean;
}
const { title = 'texo — claim-chain memory', bare = false } = Astro.props;
---

<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#08090b" />
    <title>{title}</title>

    <!-- Self-hosted fonts (Astro Fonts API): serif preloaded (LCP claim text). -->
    <Font cssVariable="--font-instrument-serif" preload />
    <Font cssVariable="--font-space-mono" />
    <Font cssVariable="--font-dm-sans" />

    <style>
      /* ── Token layer ── each @token block resolves against src/tokens and
         compiles to a :root --czap-<name> custom property. */
      @token primary {}
      @token secondary {}
      @token surface {}
      @token panel {}
      @token text {}
      @token muted {}
      @token border {}
      @token current {}
      @token stale {}
      @token conflict {}
      /* ── Theme layer ── variant selectors emitted from src/themes; empty body. */
      @theme dark {}
    </style>
  </head>

  <body>
    <canvas class="ledger-canvas" id="ledger-canvas" aria-hidden="true"></canvas>
    {!bare && (
      <header class="led-head">
        <a class="led-head__brand mono" href="/">
          <span class="led-head__spine" aria-hidden="true"></span>texo
        </a>
        <span class="led-head__tag eyebrow">claim-chain memory</span>
        <nav class="led-head__nav">
          <a class="led-head__link mono" href="/">agent</a>
          <a class="led-head__link mono" href="/audit.html">self-audit</a>
          <a class="led-head__link mono" href="/studio.html">studio</a>
        </nav>
        <span class="led-head__spacer"></span>
        <span class="led-head__status mono" id="stream-status" data-live="false">
          <span class="led-head__dot" aria-hidden="true"></span>stream
        </span>
      </header>
    )}

    <main>
      <slot />
    </main>

    {!bare && (
      <aside class="hud mono" id="frontier-hud" aria-label="live memory state">
        <div class="hud__title eyebrow">memory · live</div>
        <dl class="hud__grid">
          <div><dt>frontier</dt><dd class="seq" id="hud-frontier">—</dd></div>
          <div><dt>current</dt><dd class="seq" id="hud-current" data-k="current">—</dd></div>
          <div><dt>stale</dt><dd class="seq" id="hud-stale" data-k="stale">—</dd></div>
          <div><dt>conflict</dt><dd class="seq" id="hud-conflict" data-k="conflict">—</dd></div>
          <div class="hud__wide"><dt>settlement</dt><dd class="seq" id="hud-settle">—</dd></div>
        </dl>
      </aside>
    )}

    <style is:global>
      /* ── the generative ledger field (WebGL), behind everything ── */
      .ledger-canvas { position: fixed; inset: 0; width: 100%; height: 100%; z-index: -1; pointer-events: none; opacity: 0; transition: opacity 1.2s var(--ease-house); }
      html[data-field='on'] .ledger-canvas { opacity: 1; }

      /* ── ledger header: a thin ruled bar ── */
      .led-head {
        position: sticky; top: 0; z-index: 100;
        display: flex; align-items: center; gap: 1rem;
        padding: 0.7rem var(--gutter);
        background: color-mix(in srgb, var(--ink-0) 82%, transparent);
        backdrop-filter: blur(14px) saturate(1.2);
        border-bottom: 1px solid var(--rule);
      }
      .led-head__brand {
        display: inline-flex; align-items: center; gap: 0.5rem;
        font-weight: 700; font-size: 1.05rem; letter-spacing: -0.03em;
        color: var(--paper); text-decoration: none;
      }
      .led-head__spine { width: 3px; height: 1.05em; background: var(--frontier); box-shadow: 0 0 10px color-mix(in srgb, var(--frontier) 60%, transparent); }
      .led-head__tag { display: none; }
      @media (min-width: 620px) { .led-head__tag { display: inline; } }
      .led-head__nav { display: flex; gap: 1rem; margin-left: 0.5rem; }
      .led-head__link {
        font-size: var(--t-label); text-transform: uppercase; letter-spacing: 0.16em;
        color: var(--paper-faint); text-decoration: none; transition: color var(--dur-hover) var(--ease-house);
      }
      .led-head__link:hover { color: var(--live); }
      .led-head__spacer { flex: 1; }
      .led-head__status { display: inline-flex; align-items: center; gap: 0.45rem; font-size: var(--t-label); text-transform: uppercase; letter-spacing: 0.16em; color: var(--paper-faint); }
      .led-head__dot { width: 7px; height: 7px; border-radius: 50%; background: var(--paper-faint); transition: background var(--dur-hover); }
      .led-head__status[data-live='true'] .led-head__dot { background: var(--live); box-shadow: 0 0 8px var(--live); animation: pulse 2.4s ease-in-out infinite; }
      .led-head__status[data-live='error'] .led-head__dot { background: var(--conflict); }
      @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.4; } }

      /* ── Frontier HUD: machinery made visible ── */
      .hud {
        position: fixed; bottom: 1rem; left: 1rem; z-index: 200;
        padding: 0.7rem 0.85rem;
        background: color-mix(in srgb, var(--ink-1) 88%, transparent);
        backdrop-filter: blur(12px);
        border: 1px solid var(--rule-strong);
        font-size: var(--t-label);
        min-width: 12.5rem;
        box-shadow: 0 8px 30px rgba(0,0,0,0.4);
      }
      .hud__title { margin-bottom: 0.5rem; color: var(--live); display: flex; align-items: center; gap: 0.4rem; }
      .hud__title::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: var(--live); box-shadow: 0 0 6px var(--live); }
      .hud__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.3rem 0.9rem; }
      .hud__grid dt { color: var(--paper-faint); text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.6rem; }
      .hud__grid dd { color: var(--paper); font-variant-numeric: tabular-nums; }
      .hud__grid dd[data-k='current'] { color: var(--current); }
      .hud__grid dd[data-k='stale'] { color: var(--stale); }
      .hud__grid dd[data-k='conflict'] { color: var(--conflict); }
      .hud__wide { grid-column: 1 / -1; }
      @media (max-width: 560px) { .hud { display: none; } }
    </style>

    <script>
      import { initMood } from '../lib/mood';
      import { initLedgerField } from '../lib/ledger-field';

      // ── reveal: IntersectionObserver → .is-visible, one-shot (house curve does the rest)
      const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
      const reveals = document.querySelectorAll<HTMLElement>('.reveal');
      if (reduce) {
        reveals.forEach((el) => el.classList.add('is-visible'));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); }
            }
          },
          { rootMargin: '0px 0px -80px 0px', threshold: 0.05 },
        );
        reveals.forEach((el) => io.observe(el));
      }

      // ── the ledger mood engine (scroll.progress → eased --mem-heat + data-mood), every page
      initMood();

      // ── the generative WebGL ledger field — enhancement only, self-gates on tier/motion
      const cv = document.getElementById('ledger-canvas') as HTMLCanvasElement | null;
      if (cv) initLedgerField(cv);
    </script>
  </body>
</html>
