---
import Base from '../layouts/Base.astro';
---

<Base title="texo — claim-chain memory">
  <!-- ═══ ACT I · THE FRONTIER ══════════════════════════════════════════ -->
  <section class="act hero wrap">
    <p class="eyebrow reveal">claim-chain memory · append-only · receipts on every answer</p>
    <h1 class="hero__title reveal" data-delay="1">
      Memory that knows<br /><em>when to stop believing</em> things.
    </h1>
    <p class="hero__lead sans reveal" data-delay="2">
      Every fact you state becomes a journaled <span class="frontier-mark">claim</span>.
      When a fact changes, the old claim isn't buried in a vector index — it's
      <span class="strike">struck</span>, sealed with a receipt, and superseded on the record.
      Git tracks code diffs. <strong>texo tracks claim diffs.</strong>
    </p>
    <div class="hero__meta mono reveal" data-delay="3">
      <span class="addr-chip">journal · canonical</span>
      <span class="seq">frontier <b id="hero-frontier">—</b></span>
      <a class="hero__cta press" href="#journey">trace a claim ↓</a>
    </div>
  </section>

  <!-- ═══ ACT · THE MAP — a claim's journey ═════════════════════════════ -->
  <section class="act wrap diagram" id="journey">
    <header class="sec-head reveal">
      <span class="eyebrow">the map</span>
      <h2 class="serif">The journey of a claim.</h2>
      <p class="sec-head__sub sans">Every fact you state walks the same pipeline. The heuristic floor and the Qwen judge decide, per claim, whether it lands as new truth, retires an older claim, or opens a conflict — and the record keeps all three.</p>
    </header>

    <figure class="dg reveal" data-delay="1">
      <svg class="dg-svg" viewBox="0 0 900 700" role="img"
           aria-label="Flowchart. A stated fact is ingested; claims are extracted by the heuristic floor and Qwen; each claim is judged against the frontier and routed to one of three outcomes — appended as new current truth, superseding an older claim through a struck-and-sealed receipt, or flagged as an open conflict — before the answer is returned with receipts.">
        <defs>
          <marker id="dg-tip" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
            <path d="M0 0 L10 5 L0 10 z" fill="context-stroke" />
          </marker>
        </defs>

        <!-- edges (under the nodes) -->
        <g class="dg-edges" fill="none" marker-end="url(#dg-tip)">
          <path class="dg-edge dg-spine" d="M450 80 L450 132" />
          <path class="dg-edge dg-spine" d="M450 196 L450 248" />
          <path class="dg-edge dg-e-new" d="M388 320 C 300 356, 220 360, 172 392" />
          <path class="dg-edge dg-e-chg" d="M450 320 L450 392" />
          <path class="dg-edge dg-e-con" d="M512 320 C 600 356, 680 360, 728 392" />
          <path class="dg-edge dg-e-new" d="M450 468 L450 500" />
          <path class="dg-edge dg-e-new" d="M170 468 C 170 556, 300 590, 358 596" />
          <path class="dg-edge dg-e-new" d="M450 564 L450 596" />
          <path class="dg-edge dg-e-con" d="M730 468 C 730 556, 600 590, 542 596" />
        </g>

        <!-- read-head: one claim tracing the pipeline -->
        <circle class="dg-pulse" r="4.5" cx="450" cy="52" />

        <!-- edge labels -->
        <g class="dg-elabels">
          <text class="dg-elabel" x="498" y="110">ingest</text>
          <text class="dg-elabel" x="508" y="226">per claim</text>
          <text class="dg-elabel" x="250" y="350">new</text>
          <text class="dg-elabel" x="502" y="360">changed</text>
          <text class="dg-elabel" x="648" y="350">contradiction</text>
          <text class="dg-elabel" x="512" y="486">supersede</text>
        </g>

        <!-- nodes -->
        <g class="dg-nodes">
          <g class="dg-node dg-in">
            <rect x="320" y="24" width="260" height="56" />
            <text class="dg-title" x="450" y="59">you state a fact</text>
          </g>
          <g class="dg-node">
            <rect x="320" y="132" width="260" height="64" />
            <text class="dg-title" x="450" y="163">extract claims</text>
            <text class="dg-sub" x="450" y="183">heuristic floor + Qwen</text>
          </g>
          <g class="dg-node dg-decision">
            <rect x="300" y="248" width="300" height="72" />
            <text class="dg-title" x="450" y="281">judge against the frontier</text>
            <text class="dg-sub" x="450" y="303">new · changed · in conflict?</text>
          </g>
          <g class="dg-node dg-current">
            <rect x="64" y="392" width="212" height="76" />
            <text class="dg-title" x="170" y="425">append</text>
            <text class="dg-sub dg-cur-t" x="170" y="447">● new current</text>
          </g>
          <g class="dg-node dg-receipt">
            <rect x="344" y="392" width="212" height="76" />
            <text class="dg-title" x="450" y="425">strike + seal receipt</text>
            <text class="dg-sub dg-stale-t" x="450" y="447">old claim retired</text>
          </g>
          <g class="dg-node dg-conflict">
            <rect x="624" y="392" width="212" height="76" />
            <text class="dg-title" x="730" y="425">flag conflict</text>
            <text class="dg-sub dg-con-t" x="730" y="447">▲ open, unresolved</text>
          </g>
          <g class="dg-node dg-current">
            <rect x="344" y="500" width="212" height="64" />
            <text class="dg-title dg-cur-t" x="450" y="537">● current — new truth</text>
          </g>
          <g class="dg-node dg-answer">
            <rect x="300" y="596" width="300" height="64" />
            <text class="dg-title" x="450" y="623">answer — with receipts</text>
            <text class="dg-sub" x="450" y="645">source + seq on every claim</text>
          </g>
        </g>
      </svg>
    </figure>
  </section>

  <!-- ═══ ACT II · WATCH A FACT DIE ═════════════════════════════════════ -->
  <section class="act wrap" id="supersede">
    <header class="sec-head reveal">
      <span class="eyebrow">the supersession</span>
      <h2 class="serif">A fact changed. Here's the receipt.</h2>
      <p class="sec-head__sub sans">Teach a fact. Contradict it later. The old claim doesn't linger — it's retired on the record, with what replaced it, when, and from which source line.</p>
    </header>

    <div class="scene" id="scene" data-phase="0">
      <div class="scene__claim scene__claim--old claim" data-state="current">
        <p class="claim__text">Alice owns release approval.</p>
        <p class="claim__meta">meeting_notes.md:3 · <span class="seq">seq 09</span></p>
        <span class="scene__strike" aria-hidden="true"></span>
      </div>
      <div class="scene__seal" aria-hidden="true">
        <span class="scene__arrow mono">retired&nbsp;by</span>
        <span class="receipt scene__receipt"><span class="mono">receipt</span> <span class="receipt__addr">42abd965</span> · <span class="seq">seq 15</span></span>
      </div>
      <div class="scene__claim scene__claim--new claim" data-state="current">
        <p class="claim__text">Ben owns release approval now.</p>
        <p class="claim__meta">meeting_notes.md:5 · <span class="pill" style="--accent: var(--current)">current</span></p>
      </div>
    </div>

    <p class="sec-note sans reveal">
      The heuristic floor can't separate these — same subject, different words. The
      <span style="color: var(--frontier)">Qwen relation judge</span> retires the superseded claim and
      surfaces genuine contradictions as <span style="color: var(--conflict)">conflicts</span> instead of
      silently trusting the newer sentence.
    </p>
  </section>

  <!-- ═══ ACT III · THE LIVE LEDGER ═════════════════════════════════════ -->
  <section class="act wrap" id="agent">
    <header class="sec-head reveal">
      <span class="eyebrow">the live ledger</span>
      <h2 class="serif">Current truth, stale record, open conflicts.</h2>
      <p class="sec-head__sub sans">Replayed from the journal at this frontier. <span data-when="offline">Backend offline — showing the seeded ledger.</span></p>
    </header>

    <div class="rails reveal">
      <div class="rail" data-k="current">
        <div class="rail__head"><span class="rail__dot"></span>current<span class="rail__n seq" id="n-current">0</span></div>
        <ul class="rail__list" id="list-current"></ul>
      </div>
      <div class="rail" data-k="stale">
        <div class="rail__head"><span class="rail__dot"></span>stale<span class="rail__n seq" id="n-stale">0</span></div>
        <ul class="rail__list" id="list-stale"></ul>
      </div>
      <div class="rail" data-k="conflict">
        <div class="rail__head"><span class="rail__dot"></span>conflict<span class="rail__n seq" id="n-conflict">0</span></div>
        <ul class="rail__list" id="list-conflict"></ul>
      </div>
    </div>

    <form class="ask reveal" id="ask">
      <input class="ask__in mono" id="ask-in" placeholder="ask the ledger — e.g. who owns release approval?" autocomplete="off" />
      <button class="ask__btn mono press" type="submit">ask</button>
    </form>
    <div class="ask__out sans" id="ask-out" hidden></div>
  </section>

  <!-- ═══ ACT IV · DRIFT ════════════════════════════════════════════════ -->
  <section class="act wrap drift-teaser">
    <div class="reveal">
      <span class="eyebrow">the party trick</span>
      <h2 class="serif">texo audits its own docs.</h2>
      <p class="sec-head__sub sans">Feed the repo's own prose back through the pipeline and its stale architecture claims come back superseded — with receipts — by the docs that replaced them. The thesis, demonstrated on the tool.</p>
      <a class="hero__cta press" href="/drift.html">see the drift →</a>
    </div>
  </section>

  <footer class="foot mono">
    <span>texo · claim-chain memory</span>
    <span class="foot__addr">every answer carries its receipts</span>
  </footer>

  <style>
    .hero { min-height: 86vh; display: flex; flex-direction: column; justify-content: center; gap: 1.4rem; max-width: 54rem; }
    .hero__title { font-size: var(--t-display); line-height: 0.98; }
    .hero__title em { font-style: italic; color: color-mix(in srgb, var(--live) 55%, var(--paper)); }
    .hero__lead { font-size: var(--t-lead); color: var(--paper-dim); max-width: 42rem; line-height: 1.55; }
    .hero__lead strong { color: var(--paper); font-weight: 500; }
    .hero__lead .strike { color: var(--stale); text-decoration: line-through; text-decoration-color: color-mix(in srgb, var(--stale) 70%, transparent); }
    .hero__meta { display: flex; flex-wrap: wrap; gap: 0.9rem 1.2rem; align-items: center; font-size: var(--t-small); color: var(--paper-faint); }
    .hero__meta b { color: var(--live); }
    .hero__cta { color: var(--frontier); text-decoration: none; border-bottom: 1px solid color-mix(in srgb, var(--frontier) 40%, transparent); padding-bottom: 1px; transition: color var(--dur-hover), border-color var(--dur-hover); }
    .hero__cta:hover { color: var(--live); border-color: var(--live); }

    .sec-head { max-width: 44rem; margin-bottom: 2.4rem; }
    .sec-head h2 { font-size: var(--t-h1); margin-top: 0.5rem; }
    .sec-head__sub { margin-top: 0.9rem; color: var(--paper-dim); font-size: var(--t-body); line-height: 1.6; }
    .sec-note { margin-top: 2.4rem; max-width: 40rem; color: var(--paper-dim); line-height: 1.6; }

    /* ── the journey diagram (mermaid-legible, ledger-skinned) ── */
    .dg { margin: 0; overflow-x: auto; -webkit-overflow-scrolling: touch; }
    .dg-svg { display: block; width: 100%; min-width: 600px; max-width: 58rem; height: auto; margin-inline: auto; overflow: visible; }

    .dg-node rect { fill: var(--ink-1); stroke: var(--rule-strong); stroke-width: 1.25px; }
    .dg-node text { text-anchor: middle; }
    .dg-title { font-family: var(--font-serif); font-size: 21px; fill: var(--paper); letter-spacing: -0.01em; }
    .dg-sub { font-family: var(--font-mono); font-size: 12px; fill: var(--paper-faint); letter-spacing: 0.04em; text-transform: uppercase; }

    .dg-in rect       { fill: color-mix(in srgb, var(--live) 8%, var(--ink-1)); stroke: color-mix(in srgb, var(--live) 45%, transparent); }
    .dg-decision rect { fill: color-mix(in srgb, var(--frontier) 10%, var(--ink-1)); stroke: var(--frontier); stroke-width: 1.5px; }
    .dg-current rect  { stroke: color-mix(in srgb, var(--current) 55%, transparent); }
    .dg-conflict rect { stroke: color-mix(in srgb, var(--conflict) 55%, transparent); }
    .dg-answer rect   { fill: color-mix(in srgb, var(--frontier) 8%, var(--ink-1)); stroke: color-mix(in srgb, var(--frontier) 50%, transparent); }
    /* the receipt node wears the perforation: a dashed seal */
    .dg-receipt rect  { fill: var(--ink-1); stroke: color-mix(in srgb, var(--stale) 60%, transparent); stroke-dasharray: 5 4; }

    .dg-cur-t   { fill: var(--current); }
    .dg-stale-t { fill: var(--stale); }
    .dg-con-t   { fill: var(--conflict); }

    .dg-edge  { stroke-width: 1.5px; }
    .dg-spine { stroke: color-mix(in srgb, var(--frontier) 72%, transparent); }
    .dg-e-new { stroke: color-mix(in srgb, var(--current) 75%, transparent); }
    .dg-e-chg { stroke: color-mix(in srgb, var(--stale) 78%, transparent); }
    .dg-e-con { stroke: color-mix(in srgb, var(--conflict) 72%, transparent); }

    .dg-elabel { font-family: var(--font-mono); font-size: 11.5px; fill: var(--paper-dim); text-transform: uppercase; letter-spacing: 0.14em; text-anchor: middle; paint-order: stroke; stroke: var(--ink-void); stroke-width: 5px; stroke-linejoin: round; }

    /* the read-head — a single claim travelling the spine. gated: hidden unless motion is welcome */
    .dg-pulse { opacity: 0; }
    @media (prefers-reduced-motion: no-preference) {
      .dg-pulse {
        fill: var(--live);
        offset-path: path('M450 52 L450 628');
        animation: dg-travel 5.2s var(--ease-cross) infinite;
      }
    }
    @keyframes dg-travel {
      0%   { offset-distance: 0%;   opacity: 0; }
      10%  { opacity: 0.9; }
      90%  { opacity: 0.9; }
      100% { offset-distance: 100%; opacity: 0; }
    }
    :where([data-czap-motion='none']) .dg-pulse { animation: none; opacity: 0; }

    /* ── the supersession scene ── */
    .scene { max-width: 46rem; display: flex; flex-direction: column; }
    .scene__claim { position: relative; }
    .scene__strike { position: absolute; left: 1.1rem; right: 1.1rem; top: 1.5rem; height: 2px; background: var(--stale); transform: scaleX(0); transform-origin: left; box-shadow: 0 0 8px var(--stale); }
    .scene__seal { display: flex; align-items: center; gap: 1rem; padding: 0.55rem 0 0.55rem 1.35rem; opacity: 0; transform: translateY(-6px); }
    .scene__arrow { color: color-mix(in srgb, var(--frontier) 70%, transparent); font-size: var(--t-label); text-transform: uppercase; letter-spacing: 0.14em; }
    .scene__claim--new { opacity: 0; transform: translateY(12px); }

    .scene[data-phase='1'] .scene__strike,
    .scene[data-phase='2'] .scene__strike,
    .scene[data-phase='3'] .scene__strike { transform: scaleX(1); transition: transform 0.55s var(--ease-house); }
    .scene[data-phase='2'] .scene__seal,
    .scene[data-phase='3'] .scene__seal { opacity: 1; transform: none; transition: opacity 0.5s var(--ease-house), transform 0.5s var(--ease-house); }
    .scene[data-phase='3'] .scene__claim--new { opacity: 1; transform: none; transition: opacity 0.7s var(--ease-house), transform 0.7s var(--ease-house); }
    .scene[data-phase='2'] .scene__claim--old .claim__text,
    .scene[data-phase='3'] .scene__claim--old .claim__text { color: var(--paper-dim); }
    .scene[data-phase='2'] .scene__claim--old[data-state],
    .scene[data-phase='3'] .scene__claim--old[data-state] { --accent: var(--stale); }

    /* ── memory rails ── */
    .rails { display: grid; grid-template-columns: 1fr; gap: 1rem; }
    @media (min-width: 900px) { .rails { grid-template-columns: 1fr 1fr 1fr; } }
    .rail { border: 1px solid var(--rule); background: color-mix(in srgb, var(--ink-0) 60%, transparent); }
    .rail__head { display: flex; align-items: center; gap: 0.5rem; padding: 0.7rem 0.9rem; border-bottom: 1px solid var(--rule); font-family: var(--font-mono); font-size: var(--t-label); text-transform: uppercase; letter-spacing: 0.14em; color: var(--paper-dim); }
    .rail__dot { width: 7px; height: 7px; border-radius: 50%; }
    .rail[data-k='current'] .rail__dot { background: var(--current); box-shadow: 0 0 6px var(--current); }
    .rail[data-k='stale'] .rail__dot { background: var(--stale); }
    .rail[data-k='conflict'] .rail__dot { background: var(--conflict); }
    .rail__n { margin-left: auto; color: var(--paper-faint); }
    .rail__list { list-style: none; display: flex; flex-direction: column; }
    .rail__item { padding: 0.7rem 0.9rem; border-bottom: 1px solid var(--rule); border-left: 2px solid transparent; transition: background var(--dur-hover), border-color var(--dur-hover); }
    .rail__item:last-child { border-bottom: none; }
    .rail[data-k='current'] .rail__item { border-left-color: color-mix(in srgb, var(--current) 40%, transparent); }
    .rail[data-k='stale'] .rail__item { border-left-color: color-mix(in srgb, var(--stale) 40%, transparent); }
    .rail[data-k='conflict'] .rail__item { border-left-color: color-mix(in srgb, var(--conflict) 40%, transparent); }
    .rail__item:hover { background: color-mix(in srgb, var(--paper) 3%, transparent); }
    .rail__text { font-family: var(--font-serif); font-size: 1.02rem; color: var(--paper); }
    .rail[data-k='stale'] .rail__text { color: var(--paper-dim); text-decoration: line-through; text-decoration-color: color-mix(in srgb, var(--stale) 60%, transparent); }
    .rail__meta { margin-top: 0.35rem; font-family: var(--font-mono); font-size: var(--t-label); color: var(--paper-faint); overflow-wrap: anywhere; }
    .rail__meta .receipt__addr { color: var(--live); }
    .rail__new { color: var(--current); }
    .rail__empty { padding: 0.9rem; color: var(--paper-faint); font-style: italic; font-family: var(--font-sans); font-size: var(--t-small); }

    /* ── ask ── */
    .ask { display: flex; gap: 0.6rem; margin-top: 1.6rem; max-width: 46rem; }
    .ask__in { flex: 1; background: var(--ink-1); border: 1px solid var(--rule-strong); color: var(--paper); padding: 0.7rem 0.9rem; font-size: var(--t-small); }
    .ask__btn { background: color-mix(in srgb, var(--frontier) 14%, var(--ink-1)); border: 1px solid color-mix(in srgb, var(--frontier) 30%, transparent); color: color-mix(in srgb, var(--frontier) 90%, var(--paper)); padding: 0.7rem 1.1rem; text-transform: uppercase; letter-spacing: 0.14em; font-size: var(--t-label); cursor: pointer; transition: background var(--dur-hover); }
    .ask__btn:hover { background: color-mix(in srgb, var(--frontier) 24%, var(--ink-1)); }
    .ask__out { margin-top: 1rem; max-width: 46rem; padding: 0.9rem 1.1rem; border: 1px solid var(--rule); background: var(--ink-0); color: var(--paper-dim); line-height: 1.6; }
    .ask__out code { font-family: var(--font-mono); color: var(--live); }

    .drift-teaser h2 { font-size: var(--t-h1); margin-top: 0.5rem; }
    .drift-teaser .hero__cta { display: inline-block; margin-top: 1.2rem; }

    .foot { display: flex; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem; padding: 2.5rem var(--gutter); border-top: 1px solid var(--rule); color: var(--paper-faint); font-size: var(--t-label); text-transform: uppercase; letter-spacing: 0.12em; }

    [data-live='true'] [data-when='offline'] { display: none; }
  </style>

  <script>
    import { fetchState, subscribeStream, type MemoryState, type Claim } from '../lib/memory';

    const $ = (id: string) => document.getElementById(id);
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const sessionId = `ui-${(crypto as any).randomUUID?.() ?? Date.now()}`;

    function escapeHtml(s: string) { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

    function claimItem(c: Claim, k: string): string {
      const src = c.source_path ? `${c.source_path}${c.line ? ':' + c.line : ''}` : '';
      const receipt = c.receipt?.event_id ? `<span class="receipt__addr">${escapeHtml(c.receipt.event_id)}</span>${c.receipt.sequence != null ? ' · seq ' + c.receipt.sequence : ''}` : '';
      const supersede = k === 'stale' && c.superseded_by_text ? ` · → <span class="rail__new">${escapeHtml(c.superseded_by_text)}</span>` : '';
      const meta = [src, receipt].filter(Boolean).join(' · ') + supersede;
      return `<li class="rail__item"><div class="rail__text">${escapeHtml(c.text)}</div>${meta ? `<div class="rail__meta">${meta}</div>` : ''}</li>`;
    }

    function render(state: MemoryState) {
      document.documentElement.setAttribute('data-live', String(state.live));
      const set = (id: string, v: string | number) => { const el = $(id); if (el) el.textContent = String(v); };
      set('hero-frontier', state.frontier ?? '—');
      set('hud-frontier', state.frontier ?? '—');
      set('hud-current', state.current.length); set('hud-stale', state.stale.length);
      set('hud-conflict', state.conflicts.length); set('hud-settle', state.settlement);
      set('n-current', state.current.length); set('n-stale', state.stale.length); set('n-conflict', state.conflicts.length);
      const fill = (id: string, claims: Claim[], k: string) => { const el = $(id); if (el) el.innerHTML = claims.length ? claims.map((c) => claimItem(c, k)).join('') : `<li class="rail__empty">${k === 'conflict' ? 'none open' : 'nothing yet'}</li>`; };
      fill('list-current', state.current, 'current');
      fill('list-stale', state.stale, 'stale');
      fill('list-conflict', state.conflicts, 'conflict');
    }

    let current: MemoryState;
    fetchState().then((s) => { current = s; render(s); });

    // ── the kinetic supersession: staged on scroll-in (Act II) ──
    const scene = $('scene');
    if (scene) {
      if (reduce) {
        scene.setAttribute('data-phase', '3');
      } else {
        const io = new IntersectionObserver((entries) => {
          for (const e of entries) {
            if (!e.isIntersecting) continue;
            io.unobserve(e.target);
            setTimeout(() => { scene.setAttribute('data-phase', '1'); document.dispatchEvent(new CustomEvent('texo:supersede')); }, 240);
            setTimeout(() => scene.setAttribute('data-phase', '2'), 900);
            setTimeout(() => scene.setAttribute('data-phase', '3'), 1500);
          }
        }, { threshold: 0.5 });
        io.observe(scene);
      }
    }

    // ── live: on a real supersession (0xE003), refetch ──
    const statusEl = $('stream-status');
    subscribeStream({
      onHello: () => statusEl?.setAttribute('data-live', 'true'),
      onSupersede: async () => { document.dispatchEvent(new CustomEvent('texo:supersede')); current = await fetchState(); render(current); },
      onError: () => statusEl?.setAttribute('data-live', 'false'),
    });

    // ── ask the ledger (POST /api/chat; graceful when offline) ──
    const askForm = $('ask') as HTMLFormElement | null;
    askForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const input = $('ask-in') as HTMLInputElement;
      const out = $('ask-out')!;
      const q = input.value.trim();
      if (!q) return;
      out.hidden = false;
      out.textContent = 'consulting the ledger…';
      try {
        const res = await fetch('/api/chat', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ session_id: sessionId, message: q }) });
        if (!res.ok) throw new Error();
        const data = await res.json();
        out.textContent = String(data.reply ?? data.text ?? JSON.stringify(data));
      } catch {
        out.innerHTML = 'The chat endpoint needs a running <code>texo serve</code> with a Qwen key. The ledger above is live-replayed either way — that’s the point: <strong>the memory is separate from the model.</strong>';
      }
    });
  </script>
</Base>
