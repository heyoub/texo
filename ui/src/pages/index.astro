---
import Base from '../layouts/Base.astro';
import { REEL } from '../lib/replay';
---

<Base title="texo — claim-chain memory">
  <!-- ═══ ACT I · THE FRONTIER ══════════════════════════════════════════ -->
  <section class="act hero wrap">
    <p class="eyebrow reveal">claim-chain memory · append-only · receipts on every answer</p>
    <h1 class="hero__title reveal" data-delay="1">
      Memory that knows<br /><em>when to stop believing</em> things.
    </h1>
    <p class="hero__lead sans reveal" data-delay="2">
      Every fact you state becomes a journaled <span class="frontier-mark">claim</span>.
      When a fact changes, the old claim isn't buried in a vector index — it's
      <span class="strike">struck</span>, sealed with a receipt, and superseded on the record.
      Git tracks code diffs. <strong>texo tracks claim diffs.</strong>
    </p>
    <div class="hero__meta mono reveal" data-delay="3">
      <span class="addr-chip">journal · canonical</span>
      <span class="seq">frontier <b id="hero-frontier">—</b></span>
      <a class="hero__cta press" href="#journey">trace a claim ↓</a>
    </div>
  </section>

  <!-- ═══ ACT · THE MAP — a claim's journey ═════════════════════════════ -->
  <section class="act wrap diagram" id="journey">
    <header class="sec-head reveal">
      <span class="eyebrow">the map</span>
      <h2 class="serif">The journey of a claim.</h2>
      <p class="sec-head__sub sans">Every fact you state walks the same pipeline. The heuristic floor and the Qwen judge decide, per claim, whether it lands as new truth, retires an older claim, or opens a conflict — and the record keeps all three.</p>
    </header>

    <figure class="dg reveal" data-delay="1">
      <svg class="dg-svg" viewBox="0 0 900 700" role="img"
           aria-label="Flowchart. A stated fact is ingested; claims are extracted by the heuristic floor and Qwen; each claim is judged against the frontier and routed to one of three outcomes — appended as new current truth, superseding an older claim through a struck-and-sealed receipt, or flagged as an open conflict — before the answer is returned with receipts.">
        <defs>
          <marker id="dg-tip" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
            <path d="M0 0 L10 5 L0 10 z" fill="context-stroke" />
          </marker>
        </defs>

        <!-- edges (under the nodes) -->
        <g class="dg-edges" fill="none" marker-end="url(#dg-tip)">
          <path class="dg-edge dg-spine" d="M450 80 L450 132" />
          <path class="dg-edge dg-spine" d="M450 196 L450 248" />
          <path class="dg-edge dg-e-new" d="M388 320 C 300 356, 220 360, 172 392" />
          <path class="dg-edge dg-e-chg" d="M450 320 L450 392" />
          <path class="dg-edge dg-e-con" d="M512 320 C 600 356, 680 360, 728 392" />
          <path class="dg-edge dg-e-new" d="M450 468 L450 500" />
          <path class="dg-edge dg-e-new" d="M170 468 C 170 556, 300 590, 358 596" />
          <path class="dg-edge dg-e-new" d="M450 564 L450 596" />
          <path class="dg-edge dg-e-con" d="M730 468 C 730 556, 600 590, 542 596" />
        </g>

        <!-- read-head: one claim tracing the pipeline -->
        <circle class="dg-pulse" r="4.5" cx="450" cy="52" />

        <!-- edge labels -->
        <g class="dg-elabels">
          <text class="dg-elabel" x="498" y="110">ingest</text>
          <text class="dg-elabel" x="508" y="226">per claim</text>
          <text class="dg-elabel" x="250" y="350">new</text>
          <text class="dg-elabel" x="502" y="360">changed</text>
          <text class="dg-elabel" x="648" y="350">contradiction</text>
          <text class="dg-elabel" x="512" y="486">supersede</text>
        </g>

        <!-- nodes -->
        <g class="dg-nodes">
          <g class="dg-node dg-in">
            <rect x="320" y="24" width="260" height="56" />
            <text class="dg-title" x="450" y="59">you state a fact</text>
          </g>
          <g class="dg-node">
            <rect x="320" y="132" width="260" height="64" />
            <text class="dg-title" x="450" y="163">extract claims</text>
            <text class="dg-sub" x="450" y="183">heuristic floor + Qwen</text>
          </g>
          <g class="dg-node dg-decision">
            <rect x="300" y="248" width="300" height="72" />
            <text class="dg-title" x="450" y="281">judge against the frontier</text>
            <text class="dg-sub" x="450" y="303">new · changed · in conflict?</text>
          </g>
          <g class="dg-node dg-current">
            <rect x="64" y="392" width="212" height="76" />
            <text class="dg-title" x="170" y="425">append</text>
            <text class="dg-sub dg-cur-t" x="170" y="447">● new current</text>
          </g>
          <g class="dg-node dg-receipt">
            <rect x="344" y="392" width="212" height="76" />
            <text class="dg-title" x="450" y="425">strike + seal receipt</text>
            <text class="dg-sub dg-stale-t" x="450" y="447">old claim retired</text>
          </g>
          <g class="dg-node dg-conflict">
            <rect x="624" y="392" width="212" height="76" />
            <text class="dg-title" x="730" y="425">flag conflict</text>
            <text class="dg-sub dg-con-t" x="730" y="447">▲ open, unresolved</text>
          </g>
          <g class="dg-node dg-current">
            <rect x="344" y="500" width="212" height="64" />
            <text class="dg-title dg-cur-t" x="450" y="537">● current — new truth</text>
          </g>
          <g class="dg-node dg-answer">
            <rect x="300" y="596" width="300" height="64" />
            <text class="dg-title" x="450" y="623">answer — with receipts</text>
            <text class="dg-sub" x="450" y="645">source + seq on every claim</text>
          </g>
        </g>
      </svg>
    </figure>
  </section>

  <!-- ═══ ACT II · REPLAY THE FRONTIER (scroll-scrubbed timeline) ═══════ -->
  <section class="replay" id="replay" data-mode="flow">
    <header class="replay__intro sec-head reveal">
      <span class="eyebrow">the replay</span>
      <h2 class="serif">Replay the frontier.</h2>
      <p class="sec-head__sub sans">A real session, unspooled. Scroll to move the tape under the playhead — facts land, changed ones are struck and sealed with a receipt as the new truth rises, contradictions open as conflicts. Scroll back and it all reverses: you're scrubbing the record.</p>
    </header>

    <div class="replay__scroller">
      <div class="replay__stage">
        <div class="replay__head" aria-hidden="true"></div>
        <ol class="replay__tape" aria-label="Replay of the claim journal, seq 3 through 24">
          {REEL.map((b, i) => (
            <li class="rbeat" data-type={b.type} data-seq={b.seq} style={`--i:${i}`}>
              <div class="rbeat__seq mono">seq {String(b.seq).padStart(2, '0')}</div>
              <div class="rbeat__card">
                {b.type === 'append' && (
                  <Fragment>
                    <p class="rbeat__claim serif">{b.text}</p>
                    <p class="rbeat__src mono">{b.src}</p>
                    <span class="rbeat__tag pill" style="--accent: var(--current)">current</span>
                  </Fragment>
                )}
                {b.type === 'supersede' && (
                  <Fragment>
                    <p class="rbeat__old serif">{b.retires}<span class="rbeat__strikeline" aria-hidden="true"></span></p>
                    <div class="rbeat__seal receipt"><span class="mono">retired&nbsp;·&nbsp;receipt</span> <span class="receipt__addr">{b.receipt}</span></div>
                    <p class="rbeat__new serif">{b.text}</p>
                    <p class="rbeat__src mono">{b.src} · <span class="rbeat__nowtag">current</span></p>
                  </Fragment>
                )}
                {b.type === 'conflict' && (
                  <Fragment>
                    <p class="rbeat__claim serif">{b.a}</p>
                    <p class="rbeat__vs mono">⚔ contradicts</p>
                    <p class="rbeat__claim serif rbeat__claim--b">{b.b}</p>
                    <span class="rbeat__tag pill" style="--accent: var(--conflict)">open conflict</span>
                  </Fragment>
                )}
              </div>
            </li>
          ))}
        </ol>
      </div>
    </div>

    <p class="sec-note sans reveal">
      The heuristic floor can't separate <em>“Alice owns release approval”</em> from <em>“Ben owns it now”</em>
      — same subject, different words. The <span style="color: var(--frontier)">Qwen relation judge</span> retires
      the superseded claim and surfaces genuine contradictions as
      <span style="color: var(--conflict)">conflicts</span> instead of silently trusting the newer sentence.
      Everything above is real: real chains, real receipt addresses, real sequence numbers.
    </p>
  </section>

  <!-- ═══ ACT III · THE LIVE LEDGER ═════════════════════════════════════ -->
  <section class="act wrap" id="agent">
    <header class="sec-head reveal">
      <span class="eyebrow">the live ledger</span>
      <h2 class="serif">Current truth, stale record, open conflicts.</h2>
      <p class="sec-head__sub sans">Replayed from the journal at this frontier. <span data-when="offline">Backend offline — showing the seeded ledger.</span></p>
    </header>

    <div class="rails reveal">
      <div class="rail" data-k="current">
        <div class="rail__head"><span class="rail__dot"></span>current<span class="rail__n seq" id="n-current">0</span></div>
        <ul class="rail__list" id="list-current"></ul>
      </div>
      <div class="rail" data-k="stale">
        <div class="rail__head"><span class="rail__dot"></span>stale<span class="rail__n seq" id="n-stale">0</span></div>
        <ul class="rail__list" id="list-stale"></ul>
      </div>
      <div class="rail" data-k="conflict">
        <div class="rail__head"><span class="rail__dot"></span>conflict<span class="rail__n seq" id="n-conflict">0</span></div>
        <ul class="rail__list" id="list-conflict"></ul>
      </div>
    </div>

    <!-- teach → settle: drive a real supersession on-screen -->
    <div class="console reveal" id="console">
      <div class="console__bar">
        <span class="console__label eyebrow">teach the ledger</span>
        <span class="console__sid mono" id="console-sid">—</span>
        <span class="console__state mono" id="console-state">open</span>
      </div>
      <ol class="console__log" id="console-log">
        <li class="console__empty sans">State a fact. Then state one that changes it. Then <b>end&nbsp;session</b> — the relation judge retires the old claim and it re-appears <span style="color:var(--stale)">struck</span> on the stale rail, with a receipt.</li>
      </ol>
      <form class="console__form" id="teach">
        <input class="console__in mono" id="teach-in" placeholder="state a fact — e.g. “Priya owns release approval now”" autocomplete="off" />
        <button class="console__btn console__btn--state press" type="submit">state ▸</button>
      </form>
      <div class="console__egs">
        <span class="console__egs-lbl mono">try:</span>
        <button class="console__eg mono" data-say="Priya owns release approval now.">Priya owns release approval now.</button>
        <button class="console__eg mono" data-say="Actually, Dana owns release approval.">Actually, Dana owns release approval.</button>
      </div>
      <div class="console__foot">
        <button class="console__btn console__btn--end press" id="end-session" disabled>end session &amp; settle</button>
        <div class="console__receipt" id="settle-out" hidden></div>
      </div>
    </div>

    <form class="ask reveal" id="ask">
      <input class="ask__in mono" id="ask-in" placeholder="ask the ledger — e.g. who owns release approval?" autocomplete="off" />
      <button class="ask__btn mono press" type="submit">ask</button>
    </form>
    <div class="ask__out sans" id="ask-out" hidden></div>
  </section>

  <!-- ═══ ACT IV · TEXO REMEMBERS TEXO (dogfood) ═══════════════════════ -->
  <section class="act wrap dogfood" id="dogfood">
    <div class="reveal">
      <span class="eyebrow">dogfooding · on its own repository</span>
      <h2 class="serif">texo remembers texo.</h2>
      <p class="sec-head__sub sans">We pointed texo at its <b>own repository</b> — every ADR, the spec, the architecture notes — and it extracted each factual claim with a receipt back to the source line. Not a mock corpus: the tool, reading itself, catching where its own docs went stale.</p>
      <dl class="dogfood__stats mono reveal" data-delay="1">
        <div><dt>claims remembered</dt><dd id="df-claims">214</dd></div>
        <div><dt>docs ingested</dt><dd id="df-docs">12</dd></div>
        <div><dt>already superseded</dt><dd class="df-sup" id="df-sup">11</dd></div>
      </dl>
      <a class="hero__cta press reveal" data-delay="2" href="/audit.html">open the self-audit — source vs. memory →</a>
    </div>
  </section>

  <footer class="foot mono">
    <span>texo · claim-chain memory</span>
    <span class="foot__addr">every answer carries its receipts</span>
  </footer>

  <style>
    .hero { min-height: 86vh; display: flex; flex-direction: column; justify-content: center; gap: 1.4rem; max-width: 54rem; }
    .hero__title { font-size: var(--t-display); line-height: 0.98; }
    .hero__title em { font-style: italic; color: color-mix(in srgb, var(--live) 55%, var(--paper)); }
    .hero__lead { font-size: var(--t-lead); color: var(--paper-dim); max-width: 42rem; line-height: 1.55; }
    .hero__lead strong { color: var(--paper); font-weight: 500; }
    .hero__lead .strike { color: var(--stale); text-decoration: line-through; text-decoration-color: color-mix(in srgb, var(--stale) 70%, transparent); }
    .hero__meta { display: flex; flex-wrap: wrap; gap: 0.9rem 1.2rem; align-items: center; font-size: var(--t-small); color: var(--paper-faint); }
    .hero__meta b { color: var(--live); }
    .hero__cta { color: var(--frontier); text-decoration: none; border-bottom: 1px solid color-mix(in srgb, var(--frontier) 40%, transparent); padding-bottom: 1px; transition: color var(--dur-hover), border-color var(--dur-hover); }
    .hero__cta:hover { color: var(--live); border-color: var(--live); }

    .sec-head { max-width: 44rem; margin-bottom: 2.4rem; }
    .sec-head h2 { font-size: var(--t-h1); margin-top: 0.5rem; }
    .sec-head__sub { margin-top: 0.9rem; color: var(--paper-dim); font-size: var(--t-body); line-height: 1.6; }
    .sec-note { margin-top: 2.4rem; max-width: 40rem; color: var(--paper-dim); line-height: 1.6; }

    /* ── the journey diagram (mermaid-legible, ledger-skinned) ── */
    .dg { margin: 0; overflow-x: auto; -webkit-overflow-scrolling: touch; }
    .dg-svg { display: block; width: 100%; min-width: 600px; max-width: 58rem; height: auto; margin-inline: auto; overflow: visible; }

    .dg-node rect { fill: var(--ink-1); stroke: var(--rule-strong); stroke-width: 1.25px; }
    .dg-node text { text-anchor: middle; }
    .dg-title { font-family: var(--font-serif); font-size: 21px; fill: var(--paper); letter-spacing: -0.01em; }
    .dg-sub { font-family: var(--font-mono); font-size: 12px; fill: var(--paper-faint); letter-spacing: 0.04em; text-transform: uppercase; }

    .dg-in rect       { fill: color-mix(in srgb, var(--live) 8%, var(--ink-1)); stroke: color-mix(in srgb, var(--live) 45%, transparent); }
    .dg-decision rect { fill: color-mix(in srgb, var(--frontier) 10%, var(--ink-1)); stroke: var(--frontier); stroke-width: 1.5px; }
    .dg-current rect  { stroke: color-mix(in srgb, var(--current) 55%, transparent); }
    .dg-conflict rect { stroke: color-mix(in srgb, var(--conflict) 55%, transparent); }
    .dg-answer rect   { fill: color-mix(in srgb, var(--frontier) 8%, var(--ink-1)); stroke: color-mix(in srgb, var(--frontier) 50%, transparent); }
    /* the receipt node wears the perforation: a dashed seal */
    .dg-receipt rect  { fill: var(--ink-1); stroke: color-mix(in srgb, var(--stale) 60%, transparent); stroke-dasharray: 5 4; }

    .dg-cur-t   { fill: var(--current); }
    .dg-stale-t { fill: var(--stale); }
    .dg-con-t   { fill: var(--conflict); }

    .dg-edge  { stroke-width: 1.5px; }
    .dg-spine { stroke: color-mix(in srgb, var(--frontier) 72%, transparent); }
    .dg-e-new { stroke: color-mix(in srgb, var(--current) 75%, transparent); }
    .dg-e-chg { stroke: color-mix(in srgb, var(--stale) 78%, transparent); }
    .dg-e-con { stroke: color-mix(in srgb, var(--conflict) 72%, transparent); }

    .dg-elabel { font-family: var(--font-mono); font-size: 11.5px; fill: var(--paper-dim); text-transform: uppercase; letter-spacing: 0.14em; text-anchor: middle; paint-order: stroke; stroke: var(--ink-void); stroke-width: 5px; stroke-linejoin: round; }

    /* the read-head — a single claim travelling the spine. gated: hidden unless motion is welcome */
    .dg-pulse { opacity: 0; }
    @media (prefers-reduced-motion: no-preference) {
      .dg-pulse {
        fill: var(--live);
        offset-path: path('M450 52 L450 628');
        animation: dg-travel 5.2s var(--ease-cross) infinite;
      }
    }
    @keyframes dg-travel {
      0%   { offset-distance: 0%;   opacity: 0; }
      10%  { opacity: 0.9; }
      90%  { opacity: 0.9; }
      100% { offset-distance: 100%; opacity: 0; }
    }
    :where([data-czap-motion='none']) .dg-pulse { animation: none; opacity: 0; }

    /* ══ the horizontal replay ══════════════════════════════════════════ */
    .replay { position: relative; }
    .replay__intro { max-width: 44rem; margin: 0 auto 2rem; padding-inline: var(--gutter); }

    /* — flow (fallback / reduced-motion / static tier): user-swiped strip — */
    .replay[data-mode='flow'] .replay__scroller { overflow-x: auto; -webkit-overflow-scrolling: touch; scroll-snap-type: x proximity; padding-block: 1.5rem; }
    .replay[data-mode='flow'] .replay__tape { display: flex; gap: 2rem; width: max-content; padding-inline: var(--gutter); align-items: stretch; }
    .replay[data-mode='flow'] .rbeat { scroll-snap-align: center; }
    .replay[data-mode='flow'] .replay__head { display: none; }

    /* — pin (enhanced): sticky stage, scroll drives the tape under a playhead — */
    .replay[data-mode='pin'] .replay__stage { position: sticky; top: 0; height: 100vh; overflow: hidden; display: flex; align-items: center; }
    .replay[data-mode='pin'] .replay__stage::before { content: ''; position: absolute; left: 0; right: 0; top: 50%; height: 1px; background: var(--rule-strong); }
    .replay[data-mode='pin'] .replay__tape { display: flex; gap: 3.5rem; width: max-content; padding-left: 60vw; padding-right: 40vw; align-items: center; will-change: transform; }

    /* the playhead — the frontier, made a physical line */
    .replay__head { position: absolute; left: 50%; top: 14%; bottom: 14%; width: 2px; background: linear-gradient(to bottom, transparent, var(--frontier) 18%, var(--frontier) 82%, transparent); box-shadow: 0 0 18px color-mix(in srgb, var(--frontier) 70%, transparent); z-index: 4; pointer-events: none; }
    .replay__head::before { content: 'frontier'; position: absolute; top: -1.6rem; left: 50%; transform: translateX(-50%); font-family: var(--font-mono); font-size: var(--t-label); text-transform: uppercase; letter-spacing: 0.18em; color: var(--frontier); white-space: nowrap; }
    .replay__head::after { content: '▸'; position: absolute; bottom: -1.5rem; left: 50%; transform: translateX(-50%); color: var(--frontier); font-size: 0.7rem; }

    /* — a beat on the tape — */
    .replay__tape { list-style: none; }
    .rbeat { --reveal: 1; --emph: 1; flex: 0 0 auto; width: 21rem; display: flex; flex-direction: column; gap: 0.55rem; }
    .replay[data-mode='pin'] .rbeat { opacity: calc(0.28 + 0.72 * var(--emph)); }
    .rbeat__seq { font-size: var(--t-label); color: var(--paper-faint); letter-spacing: 0.16em; text-transform: uppercase; }
    .rbeat.is-head .rbeat__seq { color: var(--live); }
    .rbeat__card { position: relative; padding: 1rem 1.15rem 1.15rem; background: color-mix(in srgb, var(--ink-1) 85%, transparent); border: 1px solid var(--rule); border-left: 3px solid color-mix(in srgb, var(--current) 55%, transparent); backdrop-filter: blur(3px); }
    .rbeat[data-type='conflict'] .rbeat__card { border-left-color: color-mix(in srgb, var(--conflict) 60%, transparent); }
    .replay[data-mode='pin'] .rbeat.is-head .rbeat__card { border-color: color-mix(in srgb, var(--frontier) 35%, var(--rule)); box-shadow: 0 12px 40px rgba(0,0,0,0.45); }

    .rbeat__claim { font-size: 1.15rem; color: var(--paper); line-height: 1.32; }
    .rbeat__claim--b { color: var(--paper-dim); }
    .rbeat__src { margin-top: 0.55rem; font-size: var(--t-label); color: var(--paper-faint); letter-spacing: 0.04em; }
    .rbeat__nowtag { color: var(--current); }
    .rbeat__tag { margin-top: 0.7rem; display: inline-block; }
    .rbeat__vs { color: var(--conflict); font-size: var(--t-label); text-transform: uppercase; letter-spacing: 0.14em; margin: 0.45rem 0; }

    /* supersede internals — every value a pure function of --reveal (reversible) */
    .rbeat__old { position: relative; display: inline-block; color: var(--paper-dim); font-size: 1.05rem; line-height: 1.3; transform: translateY(calc(var(--reveal) * 12px)); opacity: calc(1 - var(--reveal) * 0.4); }
    .rbeat__strikeline { position: absolute; left: 0; top: 50%; height: 2px; background: var(--stale); box-shadow: 0 0 8px var(--stale); width: calc(clamp(0, (var(--reveal) - 0.25) * 2.6, 1) * 100%); }
    .rbeat__seal { margin: 0.55rem 0; opacity: clamp(0, (var(--reveal) - 0.42) * 3.2, 1); transform: translateY(calc((1 - clamp(0, (var(--reveal) - 0.42) * 3.2, 1)) * -6px)); }
    .rbeat__new { color: var(--paper); font-size: 1.15rem; line-height: 1.32; opacity: clamp(0, (var(--reveal) - 0.58) * 3, 1); transform: translateY(calc((1 - clamp(0, (var(--reveal) - 0.58) * 3, 1)) * 14px)); }
    .rbeat[data-type='supersede'] .rbeat__src { opacity: clamp(0, (var(--reveal) - 0.7) * 4, 1); }

    .replay .sec-note { margin-inline: auto; max-width: 44rem; padding-inline: var(--gutter); margin-top: 3rem; }

    /* ── memory rails ── */
    .rails { display: grid; grid-template-columns: 1fr; gap: 1rem; }
    @media (min-width: 900px) { .rails { grid-template-columns: 1fr 1fr 1fr; } }
    .rail { border: 1px solid var(--rule); background: color-mix(in srgb, var(--ink-0) 60%, transparent); }
    .rail__head { display: flex; align-items: center; gap: 0.5rem; padding: 0.7rem 0.9rem; border-bottom: 1px solid var(--rule); font-family: var(--font-mono); font-size: var(--t-label); text-transform: uppercase; letter-spacing: 0.14em; color: var(--paper-dim); }
    .rail__dot { width: 7px; height: 7px; border-radius: 50%; }
    .rail[data-k='current'] .rail__dot { background: var(--current); box-shadow: 0 0 6px var(--current); }
    .rail[data-k='stale'] .rail__dot { background: var(--stale); }
    .rail[data-k='conflict'] .rail__dot { background: var(--conflict); }
    .rail__n { margin-left: auto; color: var(--paper-faint); }
    .rail__list { list-style: none; display: flex; flex-direction: column; }
    .rail__item { padding: 0.7rem 0.9rem; border-bottom: 1px solid var(--rule); border-left: 2px solid transparent; transition: background var(--dur-hover), border-color var(--dur-hover); }
    .rail__item:last-child { border-bottom: none; }
    .rail[data-k='current'] .rail__item { border-left-color: color-mix(in srgb, var(--current) 40%, transparent); }
    .rail[data-k='stale'] .rail__item { border-left-color: color-mix(in srgb, var(--stale) 40%, transparent); }
    .rail[data-k='conflict'] .rail__item { border-left-color: color-mix(in srgb, var(--conflict) 40%, transparent); }
    .rail__item:hover { background: color-mix(in srgb, var(--paper) 3%, transparent); }
    .rail__text { font-family: var(--font-serif); font-size: 1.02rem; color: var(--paper); }
    .rail[data-k='stale'] .rail__text { color: var(--paper-dim); text-decoration: line-through; text-decoration-color: color-mix(in srgb, var(--stale) 60%, transparent); }
    .rail__meta { margin-top: 0.35rem; font-family: var(--font-mono); font-size: var(--t-label); color: var(--paper-faint); overflow-wrap: anywhere; }
    .rail__meta .receipt__addr { color: var(--live); }
    .rail__new { color: var(--current); }
    .rail__empty { padding: 0.9rem; color: var(--paper-faint); font-style: italic; font-family: var(--font-sans); font-size: var(--t-small); }

    /* ══ teach → settle console ══════════════════════════════════════════ */
    .console { margin-top: 1.6rem; max-width: 46rem; border: 1px solid var(--rule-strong); background: color-mix(in srgb, var(--ink-0) 70%, transparent); }
    .console__bar { display: flex; align-items: center; gap: 0.7rem; padding: 0.55rem 0.9rem; border-bottom: 1px solid var(--rule); }
    .console__label { color: var(--paper-dim); }
    .console__sid { margin-left: auto; font-size: var(--t-label); color: var(--paper-faint); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 10rem; }
    .console__state { font-size: var(--t-label); text-transform: uppercase; letter-spacing: 0.14em; color: var(--live); }

    .console__log { list-style: none; margin: 0; padding: 0.5rem 0; max-height: 15rem; overflow-y: auto; }
    .console__empty { padding: 0.7rem 0.95rem; color: var(--paper-faint); font-size: var(--t-small); line-height: 1.55; }
    .console__line { display: flex; align-items: baseline; gap: 0.55rem; padding: 0.5rem 0.95rem; border-left: 2px solid color-mix(in srgb, var(--frontier) 45%, transparent); }
    .console__line.is-journaled { border-left-color: color-mix(in srgb, var(--current) 55%, transparent); }
    .console__line.is-warn { border-left-color: color-mix(in srgb, var(--stale) 55%, transparent); }
    .console__line.is-err { border-left-color: color-mix(in srgb, var(--conflict) 55%, transparent); }
    .console__line.is-sealed { opacity: 0.6; }
    .console__prompt { color: var(--frontier); font-family: var(--font-mono); }
    .console__said { font-family: var(--font-serif); font-size: 1.05rem; color: var(--paper); flex: 1; }
    .console__meta { font-family: var(--font-mono); font-size: var(--t-label); color: var(--paper-faint); letter-spacing: 0.03em; white-space: nowrap; }
    .console__meta[data-kind='ok'] { color: var(--current); }
    .console__meta[data-kind='warn'] { color: var(--stale); }
    .console__meta[data-kind='err'] { color: var(--conflict); }

    .console__form { display: flex; gap: 0; border-top: 1px solid var(--rule); }
    .console__in { flex: 1; background: var(--ink-1); border: none; color: var(--paper); padding: 0.75rem 0.95rem; font-size: var(--t-small); }
    .console__in:focus-visible { outline: none; box-shadow: inset 0 0 0 1px var(--frontier); }
    .console__btn { font-family: var(--font-mono); font-size: var(--t-label); text-transform: uppercase; letter-spacing: 0.14em; cursor: pointer; transition: background var(--dur-hover), color var(--dur-hover), border-color var(--dur-hover); }
    .console__btn--state { padding: 0.75rem 1.2rem; background: color-mix(in srgb, var(--frontier) 16%, var(--ink-1)); border: none; border-left: 1px solid var(--rule); color: color-mix(in srgb, var(--frontier) 92%, var(--paper)); }
    .console__btn--state:hover { background: color-mix(in srgb, var(--frontier) 26%, var(--ink-1)); }

    .console__egs { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; padding: 0.6rem 0.95rem; border-top: 1px solid var(--rule); }
    .console__egs-lbl { font-size: var(--t-label); text-transform: uppercase; letter-spacing: 0.14em; color: var(--paper-faint); }
    .console__eg { font-size: var(--t-label); color: var(--paper-dim); background: transparent; border: 1px dashed var(--rule-strong); padding: 0.3rem 0.6rem; cursor: pointer; transition: border-color var(--dur-hover), color var(--dur-hover); }
    .console__eg:hover { color: var(--paper); border-color: color-mix(in srgb, var(--frontier) 50%, transparent); }

    .console__foot { display: flex; align-items: center; gap: 0.9rem; flex-wrap: wrap; padding: 0.7rem 0.95rem; border-top: 1px solid var(--rule); background: color-mix(in srgb, var(--ink-1) 40%, transparent); }
    .console__btn--end { padding: 0.6rem 1.1rem; background: color-mix(in srgb, var(--live) 14%, var(--ink-1)); border: 1px solid color-mix(in srgb, var(--live) 34%, transparent); color: color-mix(in srgb, var(--live) 92%, var(--paper)); }
    .console__btn--end:hover:not(:disabled) { background: color-mix(in srgb, var(--live) 24%, var(--ink-1)); border-color: var(--live); }
    .console__btn--end:disabled { opacity: 0.4; cursor: not-allowed; }

    .console__receipt { font-family: var(--font-mono); font-size: var(--t-small); color: var(--paper-dim); }
    .console__receipt.is-pending { color: var(--paper-faint); font-style: italic; }
    .console__receipt.is-err { color: color-mix(in srgb, var(--conflict) 80%, var(--paper)); }
    .console__receipt.is-sealed { display: inline-flex; align-items: center; gap: 0.6rem; padding: 0.4rem 0.75rem; background: var(--ink-1); border: 1px dashed var(--rule-strong);
      mask:
        radial-gradient(4px 4px at 8px -2px, transparent 96%, #000) repeat-x top / 16px 6px,
        radial-gradient(4px 4px at 8px calc(100% + 2px), transparent 96%, #000) repeat-x bottom / 16px 6px,
        linear-gradient(#000, #000) center / 100% calc(100% - 8px) no-repeat; }
    .console__seal-tag { color: var(--live); text-transform: uppercase; letter-spacing: 0.14em; font-size: var(--t-label); }
    .console__seal-nums b { color: var(--paper); font-variant-numeric: tabular-nums; }
    .console__seal-nums .n-stale { color: var(--stale); }
    .console__seal-nums .n-con { color: var(--conflict); }

    /* ── ask ── */
    .ask { display: flex; gap: 0.6rem; margin-top: 1.6rem; max-width: 46rem; }
    .ask__in { flex: 1; background: var(--ink-1); border: 1px solid var(--rule-strong); color: var(--paper); padding: 0.7rem 0.9rem; font-size: var(--t-small); }
    .ask__btn { background: color-mix(in srgb, var(--frontier) 14%, var(--ink-1)); border: 1px solid color-mix(in srgb, var(--frontier) 30%, transparent); color: color-mix(in srgb, var(--frontier) 90%, var(--paper)); padding: 0.7rem 1.1rem; text-transform: uppercase; letter-spacing: 0.14em; font-size: var(--t-label); cursor: pointer; transition: background var(--dur-hover); }
    .ask__btn:hover { background: color-mix(in srgb, var(--frontier) 24%, var(--ink-1)); }
    .ask__out { margin-top: 1rem; max-width: 46rem; padding: 0.9rem 1.1rem; border: 1px solid var(--rule); background: var(--ink-0); color: var(--paper-dim); line-height: 1.6; }
    .ask__out code { font-family: var(--font-mono); color: var(--live); }

    .dogfood h2 { font-size: var(--t-h1); margin-top: 0.5rem; }
    .dogfood .sec-head__sub { max-width: 46rem; margin-top: 0.9rem; }
    .dogfood b { color: var(--paper); font-weight: 500; }
    .dogfood__stats { display: flex; gap: 2.4rem; flex-wrap: wrap; margin: 1.8rem 0 0.4rem; }
    .dogfood__stats dt { font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.14em; color: var(--paper-faint); }
    .dogfood__stats dd { font-size: clamp(1.8rem, 4vw, 2.6rem); font-variant-numeric: tabular-nums; color: var(--paper); margin-top: 0.2rem; }
    .dogfood__stats .df-sup { color: var(--stale); }
    .dogfood .hero__cta { display: inline-block; margin-top: 1.2rem; }

    .foot { display: flex; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem; padding: 2.5rem var(--gutter); border-top: 1px solid var(--rule); color: var(--paper-faint); font-size: var(--t-label); text-transform: uppercase; letter-spacing: 0.12em; }

    [data-live='true'] [data-when='offline'] { display: none; }
  </style>

  <script>
    import { fetchState, subscribeStream, type MemoryState, type Claim } from '../lib/memory';
    import { initReplay } from '../lib/replay';
    import { initConsole } from '../lib/console';

    const $ = (id: string) => document.getElementById(id);
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const sessionId = `ui-${(crypto as any).randomUUID?.() ?? Date.now()}`;

    function escapeHtml(s: string) { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

    function claimItem(c: Claim, k: string): string {
      const src = c.source_path ? `${c.source_path}${c.line ? ':' + c.line : ''}` : '';
      const receipt = c.receipt?.event_id ? `<span class="receipt__addr">${escapeHtml(c.receipt.event_id)}</span>${c.receipt.sequence != null ? ' · seq ' + c.receipt.sequence : ''}` : '';
      const supersede = k === 'stale' && c.superseded_by_text ? ` · → <span class="rail__new">${escapeHtml(c.superseded_by_text)}</span>` : '';
      const meta = [src, receipt].filter(Boolean).join(' · ') + supersede;
      return `<li class="rail__item"><div class="rail__text">${escapeHtml(c.text)}</div>${meta ? `<div class="rail__meta">${meta}</div>` : ''}</li>`;
    }

    function render(state: MemoryState) {
      document.documentElement.setAttribute('data-live', String(state.live));
      const set = (id: string, v: string | number) => { const el = $(id); if (el) el.textContent = String(v); };
      set('hero-frontier', state.frontier ?? '—');
      set('hud-frontier', state.frontier ?? '—');
      set('hud-current', state.current.length); set('hud-stale', state.stale.length);
      set('hud-conflict', state.conflicts.length); set('hud-settle', state.settlement);
      set('n-current', state.current.length); set('n-stale', state.stale.length); set('n-conflict', state.conflicts.length);
      const fill = (id: string, claims: Claim[], k: string) => { const el = $(id); if (el) el.innerHTML = claims.length ? claims.map((c) => claimItem(c, k)).join('') : `<li class="rail__empty">${k === 'conflict' ? 'none open' : 'nothing yet'}</li>`; };
      fill('list-current', state.current, 'current');
      fill('list-stale', state.stale, 'stale');
      fill('list-conflict', state.conflicts, 'conflict');
    }

    let current: MemoryState;
    fetchState().then((s) => { current = s; render(s); });

    // ── the horizontal replay (Act II): scroll-scrubbed, drives the HUD ──
    const setHud = (frontier: number | string, cur: number, stale: number, con: number) => {
      const set = (id: string, v: string | number) => { const el = $(id); if (el) el.textContent = String(v); };
      set('hud-frontier', frontier); set('hud-current', cur); set('hud-stale', stale); set('hud-conflict', con);
    };
    const replaySection = $('replay');
    if (replaySection) {
      initReplay(replaySection, {
        onActive: (_i, t) => setHud(t.frontier, t.current, t.stale, t.conflict),
        onIdle: () => { if (current) render(current); },
      });
    }

    // ── the teach → settle console: drives a real supersession, refreshes the ledger ──
    const consoleEl = $('console');
    if (consoleEl) {
      initConsole(consoleEl, {
        sessionId,
        onState: (s) => { current = s; render(s); },
      });
    }

    // ── dogfood stats from the self-audit snapshot (keeps the headline honest) ──
    fetch('/self-audit.json').then((r) => (r.ok ? r.json() : null)).then((raw) => {
      if (!raw) return;
      const arr: any[] = Array.isArray(raw) ? raw : (raw.claims ?? []);
      if (!arr.length) return;
      const docs = new Set(arr.map((c) => String(c.source?.path ?? c.source_path ?? '').split('/').pop()).filter(Boolean));
      const sup = arr.filter((c) => (c.status ?? 'current') !== 'current').length;
      const set = (id: string, v: number) => { const el = $(id); if (el) el.textContent = String(v); };
      set('df-claims', arr.length); set('df-docs', docs.size); set('df-sup', sup);
    }).catch(() => {});

    // ── live: on a real supersession (0xE003), refetch ──
    const statusEl = $('stream-status');
    subscribeStream({
      onHello: () => statusEl?.setAttribute('data-live', 'true'),
      onSupersede: async () => { document.dispatchEvent(new CustomEvent('texo:supersede')); current = await fetchState(); render(current); },
      onError: () => statusEl?.setAttribute('data-live', 'false'),
    });

    // ── ask the ledger (POST /api/chat; graceful when offline) ──
    const askForm = $('ask') as HTMLFormElement | null;
    askForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const input = $('ask-in') as HTMLInputElement;
      const out = $('ask-out')!;
      const q = input.value.trim();
      if (!q) return;
      out.hidden = false;
      out.textContent = 'consulting the ledger…';
      try {
        const res = await fetch('/api/chat', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ session_id: sessionId, message: q }) });
        if (!res.ok) throw new Error();
        const data = await res.json();
        out.textContent = String(data.reply ?? data.text ?? JSON.stringify(data));
      } catch {
        out.innerHTML = 'The chat endpoint needs a running <code>texo serve</code> with a Qwen key. The ledger above is live-replayed either way — that’s the point: <strong>the memory is separate from the model.</strong>';
      }
    });
  </script>
</Base>
