---
import Base from '../layouts/Base.astro';
---

<Base title="texo remembers texo — self-audit" bare={true}>
  <section class="audit">
    <header class="audit__bar">
      <a class="audit__back mono" href="/">← ledger</a>
      <div class="audit__title">
        <span class="eyebrow">dogfooding · texo remembers texo</span>
        <h1 class="serif">Its own docs, on the record.</h1>
      </div>
      <dl class="audit__stats mono" id="audit-stats">
        <div><dt>claims</dt><dd id="st-claims">—</dd></div>
        <div><dt>docs</dt><dd id="st-docs">—</dd></div>
        <div><dt>superseded</dt><dd class="st-sup" id="st-sup">—</dd></div>
      </dl>
    </header>

    <p class="audit__lead sans" id="audit-lead">
      texo ingested its <b>own repository</b> — every ADR, the spec, the architecture notes — and
      extracted each factual claim with a receipt back to the source line. Pick a document: the left
      pane is the raw source it read, the right pane is what it remembers. Superseded claims point back
      to the exact line they were retired from.
    </p>

    <div class="audit__panes" id="audit-panes">
      <!-- doc rail -->
      <nav class="audit__docs" id="audit-docs" aria-label="documents"></nav>

      <!-- source -->
      <div class="audit__source">
        <div class="audit__source-head mono"><span id="src-name">—</span><span class="audit__source-hint" id="src-hint"></span></div>
        <div class="audit__source-body" id="src-body"><p class="audit__empty">loading the corpus…</p></div>
      </div>

      <!-- claims -->
      <aside class="audit__claims">
        <div class="audit__claims-head mono">what texo remembers<span id="claims-count"></span></div>
        <ol class="audit__claims-list" id="claims-list"></ol>
      </aside>
    </div>

    <p class="audit__note sans" id="audit-note" hidden>
      Snapshot missing — run <code>just self-audit</code> then rebuild the UI. This page reads
      <code>/self-audit.json</code> (real <code>texo claims --json</code> over the repo's own docs).
    </p>
  </section>

  <style>
    .audit { min-height: 100dvh; padding: 1.25rem var(--gutter) 3rem; display: flex; flex-direction: column; gap: 1.1rem; }
    .audit__bar { display: flex; align-items: flex-end; gap: 1.4rem; flex-wrap: wrap; padding-bottom: 1rem; border-bottom: 1px solid var(--rule); }
    .audit__back { color: var(--paper-faint); text-decoration: none; font-size: var(--t-label); text-transform: uppercase; letter-spacing: 0.16em; }
    .audit__back:hover { color: var(--live); }
    .audit__title h1 { font-size: clamp(1.6rem, 3.5vw, 2.6rem); margin-top: 0.25rem; }
    .audit__stats { margin-left: auto; display: flex; gap: 1.5rem; }
    .audit__stats dt { font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.14em; color: var(--paper-faint); }
    .audit__stats dd { font-size: 1.5rem; font-variant-numeric: tabular-nums; color: var(--paper); }
    .audit__stats .st-sup { color: var(--stale); }
    .audit__lead { max-width: 52rem; color: var(--paper-dim); font-size: var(--t-body); line-height: 1.6; }
    .audit__lead b { color: var(--paper); font-weight: 500; }

    .audit__panes { display: grid; grid-template-columns: 1fr; gap: 1rem; flex: 1; min-height: 0; }
    @media (min-width: 900px) { .audit__panes { grid-template-columns: 13rem minmax(0, 1fr) 23rem; } }

    /* doc rail */
    .audit__docs { display: flex; flex-direction: row; flex-wrap: wrap; gap: 0.4rem; align-content: flex-start; }
    @media (min-width: 900px) { .audit__docs { flex-direction: column; flex-wrap: nowrap; overflow-y: auto; } }
    .audit__doc { display: flex; align-items: baseline; gap: 0.5rem; padding: 0.5rem 0.6rem; border: 1px solid var(--rule); background: color-mix(in srgb, var(--ink-0) 55%, transparent); cursor: pointer; font-family: var(--font-mono); font-size: var(--t-label); color: var(--paper-dim); text-align: left; transition: border-color var(--dur-hover), color var(--dur-hover), background var(--dur-hover); }
    .audit__doc:hover { color: var(--paper); border-color: var(--rule-strong); }
    .audit__doc.is-active { color: var(--paper); border-color: color-mix(in srgb, var(--frontier) 50%, transparent); background: color-mix(in srgb, var(--frontier) 8%, transparent); }
    .audit__doc-n { margin-left: auto; color: var(--paper-faint); }
    .audit__doc-sup { color: var(--stale); }

    /* source pane */
    .audit__source, .audit__claims { border: 1px solid var(--rule); background: color-mix(in srgb, var(--ink-0) 45%, transparent); display: flex; flex-direction: column; min-height: 0; }
    .audit__source-head, .audit__claims-head { display: flex; align-items: center; justify-content: space-between; padding: 0.55rem 0.8rem; border-bottom: 1px solid var(--rule); font-size: var(--t-label); text-transform: uppercase; letter-spacing: 0.12em; color: var(--paper-dim); }
    .audit__source-hint { color: var(--paper-faint); text-transform: none; letter-spacing: 0; }
    .audit__source-body { overflow: auto; padding: 0.4rem 1.1rem 2.5rem; max-height: 68vh; }

    /* rendered markdown — readable prose in the ledger palette */
    .md { font-family: var(--font-sans); font-size: 0.9rem; line-height: 1.7; color: var(--paper-dim); }
    .md [data-line] { scroll-margin-top: 3rem; }
    .md h1, .md h2, .md h3, .md h4 { font-family: var(--font-serif); font-weight: 400; color: var(--paper); line-height: 1.2; letter-spacing: -0.01em; margin: 1.35em 0 0.5em; }
    .md h1 { font-size: 1.5rem; } .md h2 { font-size: 1.24rem; } .md h3 { font-size: 1.06rem; } .md h4 { font-size: 0.96rem; }
    .md h1:first-child, .md h2:first-child { margin-top: 0.2em; }
    .md p { margin: 0.6em 0; }
    .md a { color: var(--frontier); text-decoration: none; border-bottom: 1px solid color-mix(in srgb, var(--frontier) 30%, transparent); }
    .md strong { color: var(--paper); font-weight: 600; }
    .md em { font-style: italic; }
    .md code { font-family: var(--font-mono); font-size: 0.85em; background: var(--ink-1); padding: 0.1em 0.35em; border-radius: 2px; color: var(--live); overflow-wrap: anywhere; }
    .md pre { background: var(--ink-1); border: 1px solid var(--rule); padding: 0.75rem 0.9rem; overflow-x: auto; margin: 0.8em 0; }
    .md pre code { background: none; padding: 0; color: var(--paper-dim); font-size: 0.82rem; }
    .md ul, .md ol { margin: 0.6em 0; padding-left: 1.4em; }
    .md li { margin: 0.3em 0; }
    .md blockquote { border-left: 2px solid var(--rule-strong); padding-left: 1em; margin: 0.8em 0; color: var(--paper-faint); }
    .md hr { border: none; border-top: 1px solid var(--rule); margin: 1.3em 0; }
    .md table { border-collapse: collapse; margin: 0.8em 0; font-size: 0.82em; display: block; overflow-x: auto; }
    .md th, .md td { border: 1px solid var(--rule); padding: 0.35em 0.6em; text-align: left; }
    .md th { color: var(--paper); }

    /* claim-bearing blocks: a status gutter + hover/select highlight */
    .md .has-claim { border-left: 2px solid transparent; padding-left: 0.85rem; margin-left: -0.95rem; border-radius: 0 2px 2px 0; transition: background var(--dur-hover); }
    .md .has-claim.s-current { border-left-color: color-mix(in srgb, var(--current) 55%, transparent); }
    .md .has-claim.s-superseded { border-left-color: color-mix(in srgb, var(--stale) 55%, transparent); }
    .md .is-lit { background: color-mix(in srgb, var(--frontier) 14%, transparent); border-left-color: var(--frontier) !important; }

    /* claims pane */
    .audit__claims-list { list-style: none; overflow-y: auto; max-height: 68vh; }
    .audit__claim { padding: 0.7rem 0.8rem; border-bottom: 1px solid var(--rule); border-left: 3px solid transparent; cursor: pointer; transition: background var(--dur-hover); }
    .audit__claim:hover, .audit__claim.is-lit { background: color-mix(in srgb, var(--paper) 4%, transparent); }
    .audit__claim.s-current { border-left-color: color-mix(in srgb, var(--current) 45%, transparent); }
    .audit__claim.s-superseded { border-left-color: color-mix(in srgb, var(--stale) 45%, transparent); }
    .audit__claim-text { font-family: var(--font-serif); font-size: 1rem; color: var(--paper); line-height: 1.35; }
    .audit__claim.s-superseded .audit__claim-text { color: var(--paper-dim); text-decoration: line-through; text-decoration-color: color-mix(in srgb, var(--stale) 55%, transparent); }
    .audit__claim-meta { margin-top: 0.4rem; display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; font-family: var(--font-mono); font-size: var(--t-label); color: var(--paper-faint); }
    .audit__subj { padding: 0.1rem 0.4rem; border-radius: var(--radius-chip); background: color-mix(in srgb, var(--frontier) 10%, var(--ink-1)); border: 1px solid color-mix(in srgb, var(--frontier) 22%, transparent); color: color-mix(in srgb, var(--frontier) 88%, var(--paper)); }
    .audit__loc { color: var(--paper-faint); }
    .audit__rcpt { color: var(--live); }
    .audit__super { margin-top: 0.4rem; font-family: var(--font-sans); font-size: var(--t-small); color: var(--paper-dim); }
    .audit__super b { color: var(--current); font-weight: 500; }

    .audit__empty { padding: 1rem 0.8rem; color: var(--paper-faint); font-style: italic; font-family: var(--font-sans); }
    .audit__note { color: var(--paper-faint); font-size: var(--t-small); }
    .audit__note code { font-family: var(--font-mono); color: var(--live); }
  </style>

  <script>
    import { loadAudit, type AuditData, type AuditDoc, type AuditClaim } from '../lib/audit';
    import MarkdownIt from 'markdown-it';

    const md = new MarkdownIt({ html: false, linkify: true });
    // tag every block-level element with the source line it starts on, so a
    // claim can still be cross-highlighted to its exact spot in the rendered doc
    md.core.ruler.push('source_line', (state) => {
      for (const t of state.tokens) if (t.map && t.type.endsWith('_open')) t.attrSet('data-line', String(t.map[0] + 1));
      return true;
    });

    const $ = (id: string) => document.getElementById(id);
    const esc = (s: string) => { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; };

    (async () => {
      const data = await loadAudit();
      if (!data) { $('audit-note')!.hidden = false; $('src-body')!.innerHTML = ''; return; }

      $('st-claims')!.textContent = String(data.totals.claims);
      $('st-docs')!.textContent = String(data.totals.docs);
      $('st-sup')!.textContent = String(data.totals.superseded);

      // doc rail
      const rail = $('audit-docs')!;
      rail.innerHTML = data.docs.map((d, i) =>
        `<button class="audit__doc${i === 0 ? ' is-active' : ''}" data-file="${esc(d.file)}">` +
          `<span class="audit__doc-name">${esc(d.file)}</span>` +
          `<span class="audit__doc-n">${d.claims.length}${d.superseded ? ` · <span class="audit__doc-sup">${d.superseded}↓</span>` : ''}</span>` +
        `</button>`
      ).join('');

      let activeFile = data.docs[0].file;
      rail.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest('.audit__doc') as HTMLElement | null;
        if (!btn) return;
        rail.querySelectorAll('.audit__doc').forEach((b) => b.classList.toggle('is-active', b === btn));
        activeFile = btn.dataset.file!;
        selectDoc(activeFile);
      });

      const srcCache = new Map<string, string>();
      async function selectDoc(file: string) {
        const doc = data!.docs.find((d) => d.file === file)!;
        $('src-name')!.textContent = file;
        $('src-hint')!.textContent = `${doc.claims.length} claims · ${doc.superseded} superseded`;
        $('claims-count')!.textContent = ` ${doc.claims.length}`;

        // source
        let text = srcCache.get(file);
        if (text == null) {
          try { const r = await fetch(doc.path); text = r.ok ? await r.text() : ''; }
          catch { text = ''; }
          srcCache.set(file, text);
        }
        renderSource(doc, text);
        renderClaims(doc);
      }

      let srcBlocks: { el: HTMLElement; line: number }[] = [];
      function blockForLine(line: number): HTMLElement | null {
        let hit: HTMLElement | null = null;
        for (const b of srcBlocks) { if (b.line <= line) hit = b.el; else break; }
        return hit;
      }
      function renderSource(doc: AuditDoc, text: string) {
        const body = $('src-body')!;
        if (!text) { body.innerHTML = `<p class="audit__empty">source not snapshotted — run <code>just self-audit</code></p>`; return; }
        body.innerHTML = `<div class="md">${md.render(text)}</div>`;
        srcBlocks = Array.from(body.querySelectorAll<HTMLElement>('[data-line]'))
          .map((el) => ({ el, line: parseInt(el.getAttribute('data-line') || '0', 10) }))
          .sort((a, b) => a.line - b.line);
        // mark the block each claim came from, colour it by status, remember the claim lines
        for (const c of doc.claims) {
          if (c.line == null) continue;
          const el = blockForLine(c.line);
          if (!el) continue;
          el.classList.add('has-claim', c.status === 'current' ? 's-current' : 's-superseded');
          el.dataset.claimLines = `${el.dataset.claimLines || ''} ${c.line}`.trim();
        }
      }

      function renderClaims(doc: AuditDoc) {
        const list = $('claims-list')!;
        list.innerHTML = doc.claims.map((c) => {
          const loc = c.line != null ? `${doc.file}:${c.line}` : doc.file;
          const seq = c.receipt?.sequence != null ? ` · <span class="audit__rcpt">seq ${c.receipt.sequence}</span>` : '';
          const subj = c.subject_hint ? `<span class="audit__subj">${esc(c.subject_hint)}</span>` : '';
          const winner = c.superseded_by ? data!.byId.get(c.superseded_by) : null;
          const sup = winner ? `<div class="audit__super">↳ now: <b>${esc(winner.text)}</b></div>` : '';
          const st = c.status === 'current' ? 's-current' : 's-superseded';
          return `<li class="audit__claim ${st}" data-line="${c.line ?? ''}">` +
            `<div class="audit__claim-text">${esc(c.text)}</div>` +
            `<div class="audit__claim-meta">${subj}<span class="audit__loc">${esc(loc)}</span>${seq}</div>` +
            sup +
          `</li>`;
        }).join('');
      }

      // cross-highlight: claim <-> source line
      const srcBody = $('src-body')!;
      const claimsList = $('claims-list')!;
      function litBlock(line: string | null, scroll: boolean) {
        srcBody.querySelectorAll('.md .is-lit').forEach((el) => el.classList.remove('is-lit'));
        if (!line) return;
        const el = blockForLine(parseInt(line, 10));
        if (el) { el.classList.add('is-lit'); if (scroll) el.scrollIntoView({ block: 'center', behavior: 'smooth' }); }
      }
      claimsList.addEventListener('mouseover', (e) => { const li = (e.target as HTMLElement).closest('.audit__claim') as HTMLElement; if (li) litBlock(li.dataset.line || null, false); });
      claimsList.addEventListener('click', (e) => { const li = (e.target as HTMLElement).closest('.audit__claim') as HTMLElement; if (li) litBlock(li.dataset.line || null, true); });
      srcBody.addEventListener('mouseover', (e) => {
        const blk = (e.target as HTMLElement).closest('[data-line]') as HTMLElement;
        claimsList.querySelectorAll('.audit__claim.is-lit').forEach((el) => el.classList.remove('is-lit'));
        if (!blk || !blk.dataset.claimLines) return;
        for (const ln of blk.dataset.claimLines.split(' ')) {
          claimsList.querySelectorAll(`.audit__claim[data-line="${ln}"]`).forEach((el) => el.classList.add('is-lit'));
        }
      });

      selectDoc(activeFile);
    })();
  </script>
</Base>
