---
import Base from '../layouts/Base.astro';
---

<Base title="texo — drift">
  <section class="drift-head">
    <h1>Drift: texo on its own prose</h1>
    <p>
      This is a snapshot of texo ingesting this repository's own markdown —
      README, ADRs, specs, hackathon notes. Claims about the old architecture
      surface as <strong>superseded</strong> by the docs that replaced them;
      nothing is deleted, everything carries its receipt. Generated by
      <code>just drift-ui</code>.
    </p>
    <div class="drift-counts" id="drift-counts"></div>
  </section>

  <section class="panel" aria-label="Superseded claims">
    <header class="panel__head">
      <h2 class="head--stale">Superseded</h2>
      <span class="panel__meta">old truths, retired with receipts</span>
    </header>
    <ul class="drift-list" id="drift-stale"><li class="drift-empty">loading…</li></ul>
  </section>

  <section class="panel" aria-label="Conflicting claims">
    <header class="panel__head">
      <h2 class="head--conflict">Conflicting</h2>
      <span class="panel__meta">open disputes, both sides shown</span>
    </header>
    <ul class="drift-list" id="drift-conflict"><li class="drift-empty">loading…</li></ul>
  </section>

  <section class="panel" aria-label="Current claims">
    <header class="panel__head">
      <h2 class="head--current">Current</h2>
      <span class="panel__meta">what the docs assert today</span>
    </header>
    <ul class="drift-list" id="drift-current"><li class="drift-empty">loading…</li></ul>
  </section>
</Base>

<style>
  .drift-head {
    margin-bottom: 1.25rem;
    max-width: 46rem;
  }
  .drift-head h1 {
    font-size: 1.375rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }
  .drift-head p {
    margin-top: 0.5rem;
    font-size: 0.9375rem;
    color: var(--czap-muted);
  }
  .drift-head code {
    font-family: ui-monospace, monospace;
    font-size: 0.85em;
    background: var(--czap-panel);
    border: 1px solid var(--czap-border);
    padding: 0.05rem 0.35rem;
    border-radius: 0.25rem;
  }

  .drift-counts {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.75rem;
    flex-wrap: wrap;
  }
  .drift-counts :global(.count) {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.2rem 0.6rem;
    border-radius: 0.75rem;
    border: 1px solid var(--czap-border);
    background: var(--czap-panel);
  }
  .drift-counts :global(.count--current) { color: var(--czap-current); }
  .drift-counts :global(.count--stale) { color: var(--czap-stale); }
  .drift-counts :global(.count--conflict) { color: var(--czap-conflict); }

  .panel {
    background: var(--czap-panel);
    border: 1px solid var(--czap-border);
    border-radius: 0.75rem;
    padding: 1rem;
    margin-bottom: 1rem;
  }
  .panel__head {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }
  .panel__head h2 {
    font-size: 0.9375rem;
    font-weight: 700;
  }
  .head--current { color: var(--czap-current); }
  .head--stale { color: var(--czap-stale); }
  .head--conflict { color: var(--czap-conflict); }
  .panel__meta {
    font-size: 0.71875rem;
    color: var(--czap-muted);
    margin-left: auto;
  }

  .drift-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    font-size: 0.8125rem;
  }
  .drift-list :global(li) {
    padding: 0.5rem 0.65rem;
    border-radius: 0.5rem;
    background: var(--czap-surface);
    border-left: 3px solid var(--czap-border);
    overflow-wrap: anywhere;
  }
  #drift-current :global(li) { border-left-color: var(--czap-current); }
  #drift-stale :global(li) { border-left-color: var(--czap-stale); }
  #drift-conflict :global(li) { border-left-color: var(--czap-conflict); }

  .drift-list :global(.drift-empty) {
    color: var(--czap-muted);
    font-style: italic;
    background: transparent;
    border-left-color: transparent;
  }
  .drift-list :global(.claim__src) {
    display: block;
    margin-top: 0.2rem;
    font-size: 0.6875rem;
    font-family: ui-monospace, monospace;
    color: var(--czap-muted);
  }
  .drift-list :global(.claim__arrow) {
    display: block;
    margin-top: 0.2rem;
    font-size: 0.71875rem;
    color: var(--czap-stale);
  }
  .drift-list :global(.claim__tag) {
    font-size: 0.65rem;
    font-family: ui-monospace, monospace;
    color: var(--czap-primary);
    margin-right: 0.4rem;
  }
</style>

<script>
  // Renders the `just drift-ui` snapshot (ui/public/drift.json → /drift.json).
  // Shape: the CLI `claims --json` array — claim_id, text, status,
  // source {path, line_start}, receipt {event_id, sequence}, superseded_by.

  type Claim = {
    claim_id?: string;
    text?: string;
    status?: string;
    subject_hint?: string;
    superseded_by?: string;
    source?: { path?: string; line_start?: number };
    receipt?: { event_id?: string; sequence?: number };
  };

  const $ = (id: string): HTMLElement => {
    const el = document.getElementById(id);
    if (!el) throw new Error(`missing #${id}`);
    return el;
  };

  function row(claim: Claim, byId: Map<string, Claim>): HTMLLIElement {
    const li = document.createElement('li');
    if (claim.subject_hint) {
      const tag = document.createElement('span');
      tag.className = 'claim__tag';
      tag.textContent = claim.subject_hint;
      li.append(tag);
    }
    li.append(document.createTextNode(claim.text ?? ''));
    const src = document.createElement('span');
    src.className = 'claim__src';
    const path = claim.source?.path ?? '?';
    const line = claim.source?.line_start != null ? `:${claim.source.line_start}` : '';
    const seq = claim.receipt?.sequence != null ? ` · seq ${claim.receipt.sequence}` : '';
    src.textContent = `${path}${line}${seq}`;
    li.append(src);
    if (claim.status === 'superseded' && claim.superseded_by) {
      const arrow = document.createElement('span');
      arrow.className = 'claim__arrow';
      const winner = byId.get(claim.superseded_by);
      arrow.textContent = `↳ superseded by: ${winner?.text ?? claim.superseded_by}`;
      li.append(arrow);
    }
    return li;
  }

  function fill(el: HTMLElement, claims: Claim[], byId: Map<string, Claim>, empty: string): void {
    el.replaceChildren(
      ...(claims.length
        ? claims.map((claim) => row(claim, byId))
        : [Object.assign(document.createElement('li'), { className: 'drift-empty', textContent: empty })]),
    );
  }

  async function load(): Promise<void> {
    try {
      const res = await fetch('/drift.json');
      if (!res.ok) throw new Error(String(res.status));
      const claims: Claim[] = await res.json();
      const byId = new Map(claims.map((claim) => [claim.claim_id ?? '', claim]));
      const of = (status: string) => claims.filter((claim) => claim.status === status);
      const current = of('current');
      const stale = of('superseded');
      const conflict = of('conflicting');
      fill($('drift-current'), current, byId, 'none');
      fill($('drift-stale'), stale, byId, 'none — the docs agree with themselves');
      fill($('drift-conflict'), conflict, byId, 'none open');
      $('drift-counts').replaceChildren(
        Object.assign(document.createElement('span'), {
          className: 'count count--current',
          textContent: `${current.length} current`,
        }),
        Object.assign(document.createElement('span'), {
          className: 'count count--stale',
          textContent: `${stale.length} superseded`,
        }),
        Object.assign(document.createElement('span'), {
          className: 'count count--conflict',
          textContent: `${conflict.length} conflicting`,
        }),
      );
    } catch {
      const missing = 'snapshot missing — run `just drift-ui` then `pnpm build`';
      for (const id of ['drift-current', 'drift-stale', 'drift-conflict']) {
        fill($(id), [], new Map(), missing);
      }
    }
  }

  void load();
</script>
