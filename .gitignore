# Rust / Cargo
/target/
**/*.rs.bk

# Local BatPak workspace + record-once caches (created by `texo init` / `just
# demo` / the extractor). Matched at any depth: the cmd extractor's cwd is the
# docs dir, so its default cache would otherwise land under examples/.../.texo/.
.texo/

# Generated compile output (from `texo compile` / `just demo`)
/public/*
!/public/.gitkeep

# VS Code extension build artifacts
/extensions/vscode/node_modules/
/extensions/vscode/out/
/extensions/vscode/*.vsix

# Editor / OS
.idea/
.vscode/
*.swp
*~
.DS_Store

# Env / secrets
.env
.env.*

# Local agent worktrees/scratch
.claude/

# Downloaded ONNX models cached by texo-semantics smoke tests (fastembed default)
.fastembed_cache/
**/.fastembed_cache/
